// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Stores customer account information used for authentication and point tracking

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

// Stores randomly generated QR codes used for unique point claims.
model QRCode {
  id          String   @id @default(cuid())
  token       String   @unique
  pointsValue Int
  createdAt   DateTime @default(now())
  expiresAt   DateTime
}

model PointTransaction {
  id           String   @id @default(cuid())
  userId       String
  qrCodeId     String?
  pointsAmount Int
  type         String
  createdAt    DateTime @default(now())
}

model Reward {
  id         String   @id @default(cuid())
  name       String
  pointsCost Int
  isActive   Boolean
  createdAt  DateTime @default(now())
}

model Merchant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
}
